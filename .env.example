# Telegram
BOT_TOKEN=your_telegram_bot_token
MINIAPP_URL=https://<host>

# Authentication
SESSION_SECRET=change-me-to-a-random-32-char-secret
SESSION_TTL_SECONDS=86400
TMA_AUTH_MAX_AGE=3600

# LLM
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest

# Whisper STT (local Docker, run: docker compose up whisper)
WHISPER_URL=http://localhost:9000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_language_bot
# Or individual parts (used if DATABASE_URL is not set):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_language_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
